# ===========================================
# App
# ===========================================
NODE_ENV=development
PORT=3000

# ===========================================
# Database (PostgreSQL)
# Opção A: DATABASE_URL - Supabase Session pooler (região: us-east-1)
# Opção B: Variáveis individuais (PostgreSQL local)
# ===========================================
# DATABASE_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ugc

# ===========================================
# Supabase (Auth + Storage)
# Project Settings → API no dashboard
# ===========================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upload (avatar)
MAX_AVATAR_SIZE_MB=5
ALLOWED_AVATAR_MIME_TYPES=image/jpeg,image/png,image/webp
