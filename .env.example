# ===========================================
# App
# ===========================================
NODE_ENV=development
PORT=3000

# URLs do frontend (CORS e links de afiliado)
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:5173

# Operação interna: ativar/desativar parceiros de indicação (curl/Insomnia apenas).
# Nunca usar no frontend. Gerar uma chave longa e aleatória.
# INTERNAL_PARTNERS_API_KEY=

# ===========================================
# Database (PostgreSQL)
# Opção A: DATABASE_URL - Supabase Session pooler (região: us-east-1)
# Opção B: Variáveis individuais (PostgreSQL local)
# ===========================================
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ugc

# ===========================================
# Supabase (Auth + Storage)
# Project Settings → API no dashboard
# ===========================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upload (avatar)
MAX_AVATAR_SIZE_MB=5
ALLOWED_AVATAR_MIME_TYPES=image/jpeg,image/png,image/webp
AVATAR_BUCKET=avatars

# Upload (portfólio)
MAX_PORTFOLIO_UPLOAD_SIZE_MB=200
MAX_PORTFOLIO_IMAGE_SIZE_MB=10
MAX_PORTFOLIO_VIDEO_SIZE_MB=500
ALLOWED_PORTFOLIO_IMAGE_MIME_TYPES=image/jpeg,image/png,image/webp
ALLOWED_PORTFOLIO_VIDEO_MIME_TYPES=video/mp4,video/quicktime,video/webm
PORTFOLIO_IMAGE_BUCKET=portfolio-images
PORTFOLIO_VIDEO_BUCKET=portfolio-videos

# Geocoding (stub em dev; use accept_all para aceitar qualquer endereço)
GOOGLE_MAPS_API_KEY=
GEOCODING_STUB_MODE=accept_all
GEOCODING_STUB_RESPONSES={}
GEOCODING_DEFAULT_LAT=-19.9167
GEOCODING_DEFAULT_LNG=-43.9345
GEOCODING_TIMEOUT_MS=3000
DEFAULT_CREATOR_SERVICE_RADIUS_KM=30
TRANSPORT_PRICE_PER_KM=2
MIN_TRANSPORT_PRICE=20

# Billing / pagamentos / operação interna
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
API_BASE_URL=http://localhost:3000
INTERNAL_ADMIN_API_KEY=
INVITE_EXPIRY_HOURS=24

# ===========================================
# Sentry (opcional)
# ===========================================
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
# RAILWAY_GIT_COMMIT_SHA é injetado automaticamente na Railway (fallback de release)
RAILWAY_GIT_COMMIT_SHA=
